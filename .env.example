# Copy to .env and set values. Used by docker-compose and build scripts.
# HANDY_MASTER_SECRET - Required. Use a long random string for production.
HANDY_MASTER_SECRET=change-me-in-production

# Public URL where the Happy API is reachable (for CORS and app config).
# Use https://your-domain.com when nginx is in front.
PUBLIC_URL=http://localhost:3006
